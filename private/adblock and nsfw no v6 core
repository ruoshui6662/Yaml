rules:
  - RULE-SET,private_domain,直连
  - RULE-SET,private_ip,直连,no-resolve

  # 被 cn_domain 误判的检测/海外站点，强制走代理
  - RULE-SET,force_proxy,节点占位

  # NSFW 内容拦截：OISD 主规则 + ACL4SSR 补充规则
  - RULE-SET,oisd_nsfw,NSFW
  - RULE-SET,nsfw_extra,NSFW

  # 广告拦截：Mihomo 专用合并规则
  - RULE-SET,adblock,广告拦截

  # AI 服务
  - RULE-SET,ai_manual,AI
  - RULE-SET,ai,AI

  # PT 下载
  - RULE-SET,pt_tracker,PT下载

  # Apple
  - RULE-SET,apple_domain,Apple
  - RULE-SET,apple_ip,Apple,no-resolve

  # 常见海外服务
  - RULE-SET,github_domain,GitHub
  - RULE-SET,youtube_domain,YouTube
  - RULE-SET,google_domain,Google
  - RULE-SET,microsoft_domain,Microsoft
  - RULE-SET,telegram_domain,Telegram
  - RULE-SET,tiktok_domain,TikTok
  - RULE-SET,twitter_domain,X

  # 常见海外服务 IP
  - RULE-SET,google_ip,Google,no-resolve
  - RULE-SET,telegram_ip,Telegram,no-resolve
  - RULE-SET,twitter_ip,X,no-resolve

  # 国内直连
  - RULE-SET,cn_domain,直连
  - RULE-SET,cn_ip,直连,no-resolve

  # 海外域名
  - RULE-SET,geolocation-!cn,海外

  # 兜底
  - MATCH,兜底
